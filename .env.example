# ==========================================
# Notion2API 服务配置文件
# ==========================================
# 修改本文件后，重启服务才能生效：
#   uvicorn app.server:app --host 0.0.0.0 --port 8000 --reload
# ==========================================


# ----------------------------------------------------------
# 1. Notion 账号凭据（必填）
# ----------------------------------------------------------
# 格式：JSON 数组，支持配置多个账号实现轮询负载均衡
# 多账号可分散请求，减少单账号被限速的风险
#
# 如何获取（详见 README_CN.md）：
#   1. 打开 https://www.notion.so/ai 并登录
#   2. 按 F12 → Application → Cookies → 复制 token_v2 的 Value
#   3. 按 F12 → Console → 粘贴运行 scripts/extract_notion_info.js
#   4. 将脚本输出的 JSON 中 YOUR_TOKEN_V2_HERE 替换为真实 token_v2
#   5. 将完整 JSON 粘贴到下方（保留外侧单引号）
#
# 单账号示例：
# NOTION_ACCOUNTS='[{"token_v2":"你的token","space_id":"xxx","user_id":"xxx","space_view_id":"xxx","user_name":"你的名字","user_email":"你的邮箱"}]'
#
# 多账号示例：
# NOTION_ACCOUNTS='[
#   {"token_v2":"token1","space_id":"space1","user_id":"uid1","space_view_id":"view1","user_name":"账号1","user_email":"email1@xx.com"},
#   {"token_v2":"token2","space_id":"space2","user_id":"uid2","space_view_id":"view2","user_name":"账号2","user_email":"email2@xx.com"}
# ]'
NOTION_ACCOUNTS=[{"token_v2":"token1","space_id":"b24a5ddc-625c-81c0-9822-0003944c3186","user_id":"uid1","space_view_id":"view1","user_name":"账号1","user_email":"email1@xx.com"}]


# ----------------------------------------------------------
# 2. 运行模式
# ----------------------------------------------------------
# lite     — 单轮问答，无记忆，最轻量，速率限制 30次/分
# standard — 完整上下文由客户端管理，支持 Thinking 和搜索展示，速率限制 25次/分（推荐）
# heavy    — 服务端 SQLite 管理长期记忆，需配置 SILICONFLOW_API_KEY，速率限制 20次/分
APP_MODE=standard


# ----------------------------------------------------------
# 3. API 访问鉴权（可选）
# ----------------------------------------------------------
# 设置后，客户端请求 /v1 接口时需在 Header 中携带：
#   Authorization: Bearer 你设置的密钥
# 留空则不开启鉴权，任何人均可访问（本地使用时通常留空即可）
API_KEY=


# ----------------------------------------------------------
# 4. 服务网络配置
# ----------------------------------------------------------
# HOST：服务绑定的 IP 地址
#   0.0.0.0 — 允许局域网/外网访问
#   127.0.0.1 — 仅本机可访问
HOST=0.0.0.0

# PORT：服务监听端口，默认 8000
#   修改后访问地址变为 http://localhost:你设置的端口
PORT=8000

# ALLOWED_ORIGINS：允许跨域请求的来源，多个域名用逗号分隔
#   * — 允许所有来源（本地开发推荐）
#   https://example.com — 仅允许指定域名
ALLOWED_ORIGINS=*


# ----------------------------------------------------------
# 5. Heavy 模式专用配置
# ----------------------------------------------------------
# 仅 APP_MODE=heavy 时生效

# SQLite 数据库文件路径，存储完整对话历史
DB_PATH=./data/conversations.db

# SiliconFlow API Key — 用于对超出滑动窗口的历史对话进行摘要压缩
# 免费注册获取：https://siliconflow.cn
# 不配置此项则 Heavy 模式的摘要压缩功能将不可用
SILICONFLOW_API_KEY=


# ----------------------------------------------------------
# 6. 其他配置
# ----------------------------------------------------------
# 日志级别：DEBUG（最详细）/ INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# 时区设置（影响日志时间显示）
TZ=Asia/Shanghai
